{
  "name": "codevidhya-admin",
  "version": "1.0.0",
  "description": "School Admin Portal for Codevidhya",
  "scripts": {
    "install:all": "cd server && npm install && cd ../client && npm install --include=dev",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "cd client && npm run build",
    "start": "cd server && npm start"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
