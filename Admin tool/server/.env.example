# Server port
PORT=5001

# MongoDB connection string (Atlas or local)
MONGODB_URI=mongodb://localhost:27017/ai-tutor

# Path to the classroom SQLite database (relative to server/)
CLASSROOM_DB_PATH=../../teacher/classroom-ai-main/backend/classroomai.db

# Secret used to sign JWT auth tokens — change in production
JWT_SECRET=change_this_secret

# Key required to register the first admin via /api/auth/setup
ADMIN_SETUP_KEY=change_this_setup_key
