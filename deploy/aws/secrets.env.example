# ─────────────────────────────────────────────────────────────────────────────
# Codevidhya deploy secrets.  Copy this file to  secrets.env  and fill it in.
#   cp deploy/aws/secrets.env.example deploy/aws/secrets.env
# secrets.env is gitignored — it never gets committed.
#
# Most values are exactly what you already use locally — copy them from:
#   codevidhya-portal/server/.env       (portal)
#   student/Ai Tutor/server/.env        (ai tutor)
#   Admin tool/server/.env              (admin)
#   teacher/classroom-ai-main/backend/.env  (classroom)
# ─────────────────────────────────────────────────────────────────────────────

# Your EC2 public/Elastic IP, e.g. 13.234.56.78  (no http://, no port)
SERVER_IP=

# Public URLs the BROWSER uses to reach each sub-app (they open inside the
# portal via an iframe). Leave blank for a plain IP deployment — they then
# default to http://SERVER_IP:<port>. For a real DOMAIN with HTTPS you MUST set
# these to https:// URLs, otherwise the browser blocks them as mixed content.
# Point these subdomains' DNS at the server and run certbot for each.
#   PORTAL_PUBLIC_URL=https://cvtutor.codevidhya.com
#   STUDENT_PUBLIC_URL=https://aitutor.codevidhya.com
#   TEACHER_PUBLIC_URL=https://classroom.codevidhya.com
#   ADMIN_PUBLIC_URL=https://admin.codevidhya.com
PORTAL_PUBLIC_URL=
STUDENT_PUBLIC_URL=
TEACHER_PUBLIC_URL=
ADMIN_PUBLIC_URL=

# MongoDB Atlas connection strings (can all be the same cluster, different DBs)
PORTAL_MONGODB_URI=
AITUTOR_MONGODB_URI=
ADMIN_MONGODB_URI=

# JWT signing secrets — keep the SAME values you already use per app
PORTAL_JWT_SECRET=
AITUTOR_JWT_SECRET=
ADMIN_JWT_SECRET=

# Admin first-user setup key
ADMIN_SETUP_KEY=

# Groq API
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: pool of keys for automatic rotation on rate-limit (comma-separated,
# no spaces). When one key hits its limit the apps fall over to the next.
# Example: GROQ_API_KEYS=gsk_aaa,gsk_bbb,gsk_ccc
GROQ_API_KEYS=
